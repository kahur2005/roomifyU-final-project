# Copy to .env and fill in (never commit .env).
# Azure Portal → Microsoft Entra ID → App registrations → your app
AZURE_CLIENT_ID=
# Directory (tenant) ID — use "common" for multi-tenant dev if needed
AZURE_TENANT_ID=

# Optional: UPN of room/shared mailbox (otherwise defaults to signed-in user's /me calendar).
# SPIKE_CALENDAR_USER=room101@contoso.edu
